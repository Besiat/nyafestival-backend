NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=nyafestival_local
DB_PASSWORD=nyafestival_local_password
DB_DATABASE=nyafestival_local
DB_SCHEMA=public
DB_SSL=false

TOKEN_SECRET=local-dev-token-secret-change-me
