{
   "singleQuote": true,
   "trailingComma": "all",
   "semi": true,
   "tabWidth": 3,
   "printWidth": 140,
   "arrowParens": "avoid",
   "bracketSpacing": true,
   "endOfLine": "auto",
   "overrides": [
      {
         "files": "*.ts",
         "options": {
            "tabWidth": 4
         }
      }
   ]
}
