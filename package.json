{
   "name": "nyafestival-backend",
   "version": "0.0.1",
   "description": "",
   "author": "",
   "private": true,
   "license": "UNLICENSED",
   "scripts": {
      "build": "nest build",
      "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
      "start": "ts-node src/main.ts",
      "start:dev": "nest start --watch",
      "start:dev:local": "nest start --watch",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node build/main",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
      "typeorm:generate": "yarn run typeorm migration:generate -d ./src/tools/data-source.ts",
      "typeorm:run": "yarn run typeorm migration:run -d ./src/tools/data-source.ts",
      "typeorm:revert": "yarn run typeorm migration:revert -d ./src/tools/data-source.ts"
   },
   "dependencies": {
      "@nestjs-modules/mailer": "2.3.4",
      "@nestjs/common": "10.4.22",
      "@nestjs/core": "10.4.22",
      "@nestjs/jwt": "^10.2.0",
      "@nestjs/passport": "^10.0.3",
      "@nestjs/platform-express": "10.4.22",
      "@nestjs/swagger": "8.1.1",
      "@nestjs/throttler": "6.5.0",
      "@nestjs/typeorm": "^10.0.2",
      "@types/bcryptjs": "^2.4.6",
      "@types/multer": "1.4.13",
      "@types/nodemailer": "6.4.23",
      "@types/passport-jwt": "^4.0.1",
      "axios": "1.17.0",
      "bcryptjs": "^2.4.3",
      "class-transformer": "^0.5.1",
      "class-validator": "0.14.4",
      "csv-parser": "3.2.1",
      "dotenv": "16.6.1",
      "jwt-decode": "^4.0.0",
      "nodemailer": "6.10.1",
      "passport": "^0.7.0",
      "passport-google-oauth20": "^2.0.0",
      "passport-jwt": "^4.0.1",
      "passport-vk-strategy": "^1.0.0",
      "passport-vkontakte": "^0.5.0",
      "pg": "8.21.0",
      "random-string-generator": "1.0.7",
      "reflect-metadata": "^0.2.2",
      "rxjs": "7.8.2",
      "short-unique-id": "5.3.2",
      "swagger-ui-express": "^5.0.1",
      "typeorm": "0.3.30"
   },
   "devDependencies": {
      "@eslint/js": "9.39.4",
      "@nestjs/cli": "^10.4.8",
      "@nestjs/schematics": "^10.2.3",
      "@nestjs/testing": "10.4.22",
      "@types/express": "5.0.6",
      "@types/jest": "^29.5.14",
      "@types/node": "22.19.20",
      "@types/supertest": "6.0.3",
      "@typescript-eslint/eslint-plugin": "8.60.1",
      "@typescript-eslint/parser": "8.60.1",
      "eslint": "9.39.4",
      "eslint-config-prettier": "9.1.2",
      "eslint-plugin-prettier": "5.5.6",
      "globals": "14.0.0",
      "jest": "^29.7.0",
      "prettier": "3.8.3",
      "source-map-support": "^0.5.21",
      "supertest": "7.2.2",
      "ts-jest": "29.4.11",
      "ts-loader": "9.6.0",
      "ts-node": "^10.9.2",
      "tsconfig-paths": "^4.2.0",
      "typescript": "5.9.3"
   },
   "jest": {
      "moduleFileExtensions": [
         "js",
         "json",
         "ts"
      ],
      "rootDir": "src",
      "testRegex": ".*\\.spec\\.ts$",
      "transform": {
         "^.+\\.(t|j)s$": "ts-jest"
      },
      "collectCoverageFrom": [
         "**/*.(t|j)s"
      ],
      "coverageDirectory": "../coverage",
      "testEnvironment": "node"
   }
}
